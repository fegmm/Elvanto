{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    "group:monorepos",
    "group:recommended"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "Microsoft.Kiota.*"
      ],
      "groupName": "Kiota packages",
      "groupSlug": "kiota"
    },
    {
      "matchPackageNames": [
        "Microsoft.*"
      ],
      "groupName": "Microsoft packages",
      "groupSlug": "microsoft"
    },
    {
      "matchPackageNames": [
        "xunit.*"
      ],
      "groupName": "xunit packages",
      "groupSlug": "xunit"
    }
  ]
}
